# Database — Railway Postgres connection string (Variables tab → DATABASE_URL)
DATABASE_URL="postgresql://user:password@host:port/database"

# Auth.js v5 (NextAuth) — Google SSO restricted to @makailabs.ai
# Generate AUTH_SECRET locally: `openssl rand -base64 32`
AUTH_SECRET=""
# Only needed in production; Auth.js infers the URL in dev
AUTH_URL="https://sow-central.up.railway.app"
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client
# Authorized redirect URIs must include: <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Anthropic — for structured SOW extraction
ANTHROPIC_API_KEY=""
# Default extraction model. Sonnet is plenty for SOW extraction at lower cost;
# escalate to claude-opus-4-7 if accuracy on dense SOWs becomes an issue.
ANTHROPIC_MODEL="claude-sonnet-4-6"
